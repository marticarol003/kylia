# =============================================================================
# Kylia · variables de entorno
# Copia este archivo a .env.local (no se commitea) y rellena los valores reales.
# En producción se configuran en Vercel (Project Settings → Environment Variables).
#
# Esta lista es EXACTA: solo las variables que api/*.js lee de verdad (process.env).
# Sin Stripe/Telegram/Beehiiv/Next — no están cableados en el código.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase · Postgres (fuente de datos, vía PostgREST con la service key)
# https://supabase.com/dashboard/project/_/settings/api
# SUPABASE_SERVICE_KEY = la service_role key (solo backend, NUNCA en cliente).
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# Copernicus Data Space · Sentinel-2 (NDVI / NDMI / NDRE) — api/sentinel.js
# Registro gratuito en https://dataspace.copernicus.eu
# OAuth client credentials en User Settings → OAuth clients.
# -----------------------------------------------------------------------------
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Diario B · cron que congela la decisión de riego del piloto silencioso
# api/diario-b.js — por defecto DRY-RUN; DIARIO_B_LIVE=1 habilita la escritura.
# DIARIO_B_TOKEN (opcional) autentica la llamada al cron.
# -----------------------------------------------------------------------------
DIARIO_B_LIVE=
DIARIO_B_TOKEN=

# -----------------------------------------------------------------------------
# Panel de pilotos · /pilotos (admin) — api/campo.js vista=pilotos
# PILOTOS_KEY: clave de acceso. PILOTOS_JSON: configuración opcional.
# -----------------------------------------------------------------------------
PILOTOS_KEY=
PILOTOS_JSON=

# -----------------------------------------------------------------------------
# IA de texto · recomendaciones (api/ia.js) e informe científico
# GEMINI_API_KEY: free tier (obligatoria para el texto).
# ANTHROPIC_API_KEY: opcional, capa premium del informe (cascada Claude→Gemini→plantilla).
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Email · Resend (feedback in-app + recordatorio vespertino del diario)
# Dominio remitente verificado en Resend.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RECORDATORIO_FROM_EMAIL=
RECORDATORIO_TOKEN=

# -----------------------------------------------------------------------------
# Enrutado de leads y feedback (opcionales: si faltan, esos POST solo loguean)
# -----------------------------------------------------------------------------
FEEDBACK_FORWARD_EMAIL=
FEEDBACK_WEBHOOK_URL=
WAITLIST_FORWARD_EMAIL=
WAITLIST_WEBHOOK_URL=
