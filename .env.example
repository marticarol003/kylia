# =============================================================================
# Kylia · variables de entorno
# Copia este archivo a .env.local (no se commitea) y rellena los valores reales.
# =============================================================================

# -----------------------------------------------------------------------------
# Copernicus DataSpace · NDVI / NDMI vía Sentinel-2
# Registro gratuito en https://dataspace.copernicus.eu
# Genera un OAuth client en User Settings → API tokens.
# -----------------------------------------------------------------------------
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Supabase · Postgres + Auth + Storage
# https://supabase.com/dashboard/project/_/settings/api
# - URL y ANON_KEY: usadas en cliente (frontend) — son públicas.
# - SERVICE_ROLE_KEY: solo backend (api/*). NUNCA exponer en cliente.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe · Billing planes Pro y Cooperativa
# https://dashboard.stripe.com/apikeys (modo test al principio: sk_test_*)
# WEBHOOK_SECRET se genera al crear el endpoint en Webhooks.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_100=
STRIPE_PRICE_PRO_500=

# -----------------------------------------------------------------------------
# Resend · email transaccional (alertas semanales, recibos, bienvenida)
# https://resend.com/api-keys
# Dominio remitente debe estar verificado: hola@kylia.app
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=hola@kylia.app

# -----------------------------------------------------------------------------
# Telegram Bot · alertas push (@kylia_alertas_bot)
# Crear bot con @BotFather → /newbot. Token tipo 1234567:ABC...
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Newsletter · Beehiiv (gratis hasta 2.500 subs)
# https://app.beehiiv.com/settings/integrations/api
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
